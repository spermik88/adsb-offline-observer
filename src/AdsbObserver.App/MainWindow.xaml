<Window x:Class="AdsbObserver.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="clr-namespace:AdsbObserver.App.Localization"
        mc:Ignorable="d"
        Title="{x:Static loc:UiText.WindowTitle}"
        Height="920"
        Width="1560"
        MinHeight="760"
        MinWidth="1080"
        Background="#0B1218">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Margin="0,0,0,12" Background="#14202A" BorderBrush="#243746" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                    <Button Content="{x:Static loc:UiText.StartLive}" Command="{Binding StartLiveCommand}" Padding="14,8" Margin="0,0,8,8" />
                    <Button Content="{x:Static loc:UiText.Stop}" Command="{Binding StopLiveCommand}" Padding="14,8" Margin="0,0,8,8" />
                    <Button Content="{x:Static loc:UiText.Playback}" Command="{Binding StartPlaybackCommand}" Padding="14,8" Margin="0,0,8,8" />
                    <Button Content="{x:Static loc:UiText.Pause}" Command="{Binding PausePlaybackCommand}" Padding="14,8" Margin="0,0,8,8" />
                    <Button Content="{x:Static loc:UiText.RefreshSdr}" Command="{Binding RefreshDevicesCommand}" Padding="14,8" Margin="0,0,8,8" />
                    <Button Content="{x:Static loc:UiText.CheckLive}" Command="{Binding PrepareLiveCommand}" Padding="14,8" Margin="0,0,8,8" />
                    <Button Content="{x:Static loc:UiText.CenterSelected}" Command="{Binding CenterOnSelectedCommand}" Padding="14,8" Margin="0,0,8,8" />
                    <Button Content="{x:Static loc:UiText.ResetCenter}" Command="{Binding ResetCenterCommand}" Padding="14,8" Margin="0,0,8,8" />
                    <Button Content="{x:Static loc:UiText.ShowSelected}" Command="{Binding ToggleSelectedOnlyCommand}" Padding="14,8" Margin="0,0,8,8" />
                    <Button Content="{x:Static loc:UiText.MarkIncident}" Command="{Binding MarkIncidentCommand}" Padding="14,8" Margin="0,0,8,8" />
                    <Button Content="{x:Static loc:UiText.ImportRecognition}" Click="ImportRecognition_Click" Padding="14,8" Margin="0,0,8,8" />
                    <Button Content="{x:Static loc:UiText.ExportCsv}" Click="ExportCsv_Click" Padding="14,8" Margin="0,0,0,8" />
                </WrapPanel>

                <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:UiText.Layer}" Margin="0,0,8,0" Foreground="#D6E4F0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding MapLayerOptions}" SelectedValue="{Binding SelectedMapLayer}" SelectedValuePath="Value" DisplayMemberPath="Label" MinWidth="140" Margin="0,0,16,8" />
                    <TextBlock Text="{x:Static loc:UiText.Sort}" Margin="0,0,8,0" Foreground="#D6E4F0" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding SortModes}" SelectedValue="{Binding SelectedSortMode}" SelectedValuePath="Value" DisplayMemberPath="Label" MinWidth="180" Margin="0,0,16,8" />
                    <TextBlock Text="{x:Static loc:UiText.Zoom}" Margin="0,0,8,0" Foreground="#D6E4F0" VerticalAlignment="Center" />
                    <Slider Minimum="5" Maximum="12" Value="{Binding SelectedZoom}" TickFrequency="1" IsSnapToTickEnabled="True" Width="140" Margin="0,0,0,8" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,0,0,12" Padding="12" Background="#2A2618" BorderBrush="#8F6A20" BorderThickness="1" CornerRadius="10">
            <StackPanel>
                <TextBlock Text="{Binding SetupHeadlineText}" Foreground="#FCE8B2" FontWeight="SemiBold" TextWrapping="Wrap" />
                <TextBlock Text="{Binding SetupGuidanceText}" Margin="0,6,0,0" Foreground="#F8D88F" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" MinWidth="420" />
                <ColumnDefinition Width="1.2*" MinWidth="340" MaxWidth="520" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,12,0" Background="#0D141A" BorderBrush="#243746" BorderThickness="1" CornerRadius="10" Padding="8">
                <Grid>
                    <Canvas x:Name="BackgroundCanvas" />
                    <Canvas x:Name="TileCanvas" />
                    <Canvas x:Name="OverlayCanvas" />
                    <Canvas x:Name="LabelCanvas" />
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12" Padding="10" CornerRadius="8" Background="#B2152028" MaxWidth="280">
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:UiText.ObservationCenter}" Foreground="#E4EEF6" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CenterLatitude, StringFormat=Широта: {0:F4}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CenterLongitude, StringFormat=Долгота: {0:F4}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding RadiusKilometers, StringFormat=Радиус: {0:F0} км}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding MessagesPerSecondText}" Foreground="#E4EEF6" Margin="0,6,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding TrackMetricsText}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Background="#14202A" BorderBrush="#243746" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:UiText.Targets}" Foreground="#D6E4F0" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <TextBlock Text="{x:Static loc:UiText.Search}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                            <WrapPanel Margin="0,0,0,8">
                                <CheckBox Content="{x:Static loc:UiText.WithPosition}" IsChecked="{Binding WithPositionOnly}" Foreground="#D6E4F0" Margin="0,0,16,8" />
                                <CheckBox Content="{x:Static loc:UiText.AirborneOnly}" IsChecked="{Binding AirborneOnly}" Foreground="#D6E4F0" Margin="0,0,0,8" />
                            </WrapPanel>
                            <TextBlock Text="{x:Static loc:UiText.AltitudeRange}" Foreground="#AFC5D8" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding MinAltitudeText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8" ToolTip="{x:Static loc:UiText.MinAltitudeTooltip}" />
                                <TextBox Grid.Column="1" Text="{Binding MaxAltitudeText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" ToolTip="{x:Static loc:UiText.MaxAltitudeTooltip}" />
                            </Grid>
                            <TextBlock Text="{x:Static loc:UiText.SpeedRange}" Foreground="#AFC5D8" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding MinSpeedText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8" ToolTip="{x:Static loc:UiText.MinSpeedTooltip}" />
                                <TextBox Grid.Column="1" Text="{Binding MaxSpeedText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" ToolTip="{x:Static loc:UiText.MaxSpeedTooltip}" />
                            </Grid>
                            <TextBlock Text="{x:Static loc:UiText.MaxDistance}" Foreground="#AFC5D8" />
                            <TextBox Text="{Binding MaxDistanceText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" ToolTip="{x:Static loc:UiText.MaxDistanceTooltip}" />
                            <Button Content="{x:Static loc:UiText.ResetFilters}" Command="{Binding ResetFiltersCommand}" Padding="12,6" Margin="0,0,0,10" />

                            <ListBox ItemsSource="{Binding Tracks}" SelectedItem="{Binding SelectedTrack}" Background="#0F171E" BorderThickness="0" Foreground="#E7F1F8" MaxHeight="260">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Padding="10" CornerRadius="8" Background="#1A2832">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Callsign}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Icao}" Foreground="#8FB3C7" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding TrackStatusText}" Foreground="#F0C879" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" HorizontalAlignment="Right" MaxWidth="120">
                                                    <TextBlock Text="{Binding AltitudeText}" HorizontalAlignment="Right" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SpeedText}" Foreground="#8FB3C7" HorizontalAlignment="Right" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding DistanceText}" Foreground="#8FB3C7" HorizontalAlignment="Right" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <Border Background="#14202A" BorderBrush="#243746" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:UiText.SelectedTrack}" Foreground="#D6E4F0" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <TextBlock Text="{Binding SelectedTrack.Icao, TargetNullValue={x:Static loc:UiText.NoSelection}}" Foreground="#E7F1F8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrack.Callsign, StringFormat=Позывной: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrack.Registration, StringFormat=Регистрация: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrack.AircraftType, StringFormat=Тип: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrack.Operator, StringFormat=Оператор: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrack.Country, StringFormat=Страна: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrack.PositionText, StringFormat=Позиция: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding SelectedTrack.DistanceText, StringFormat=Дистанция: {0}}" Foreground="#AFC5D8" Margin="0,0,12,0" TextWrapping="Wrap" />
                                <TextBlock Grid.Column="1" Text="{Binding SelectedTrack.BearingText, StringFormat=Пеленг: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            </Grid>
                            <TextBlock Text="{Binding SelectedTrack.HeadingText, StringFormat=Курс: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrack.VerticalRateText, StringFormat=Вертикальная скорость: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrack.TrackStatusText, StringFormat=Статус: {0}, TargetNullValue={x:Static loc:UiText.NoSelection}}" Foreground="#F0C879" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrack.EmitterCategory, StringFormat=Категория излучателя: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrack.Squawk, StringFormat=Squawk: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrack.LastSeenText, StringFormat=Последний сигнал: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedTrack.LastSeenAgeText, StringFormat=Возраст: {0}}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="#14202A" BorderBrush="#243746" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:UiText.HistoryScope}" Foreground="#D6E4F0" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <TextBlock Text="{x:Static loc:UiText.IcaoFilter}" Foreground="#AFC5D8" />
                            <TextBox Text="{Binding HistoryIcaoText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                            <TextBlock Text="{x:Static loc:UiText.PeriodLocal}" Foreground="#AFC5D8" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding HistoryFromText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8" ToolTip="{x:Static loc:UiText.HistoryFromTooltip}" />
                                <TextBox Grid.Column="1" Text="{Binding HistoryToText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" ToolTip="{x:Static loc:UiText.HistoryToTooltip}" />
                            </Grid>
                            <WrapPanel Margin="0,0,0,8">
                                <CheckBox Content="{x:Static loc:UiText.SelectedOnly}" IsChecked="{Binding HistorySelectedOnly}" Foreground="#D6E4F0" Margin="0,0,16,8" />
                                <CheckBox Content="{x:Static loc:UiText.CoordinatesOnly}" IsChecked="{Binding HistoryWithCoordinatesOnly}" Foreground="#D6E4F0" Margin="0,0,0,8" />
                            </WrapPanel>
                            <TextBlock Text="{x:Static loc:UiText.HistoryHint}" Foreground="#8FB3C7" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="#14202A" BorderBrush="#243746" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:UiText.LiveStatus}" Foreground="#D6E4F0" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <TextBlock Text="{Binding ModeText}" Foreground="#D6E4F0" TextWrapping="Wrap" />
                            <TextBlock Text="{x:Static loc:UiText.Health}" Foreground="#D6E4F0" FontWeight="SemiBold" Margin="0,8,0,4" />
                            <TextBlock Text="{Binding LiveSourceText}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SourceSummaryText}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding BackendReadinessText}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DriverReadinessText}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding LiveReadinessText}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DeviceStatusText}" Foreground="#AFC5D8" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DecoderStatusText}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DecoderFailureText}" Foreground="#F0C879" TextWrapping="Wrap" />
                            <TextBlock Text="{x:Static loc:UiText.Metrics}" Foreground="#D6E4F0" FontWeight="SemiBold" Margin="0,8,0,4" />
                            <TextBlock Text="{Binding MessagesPerSecondText}" Foreground="#D6E4F0" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding TrackMetricsText}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding MapStatusText}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding RecognitionStatusText}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding AiLogsStatusText}" Foreground="#AFC5D8" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CapabilitiesText}" Foreground="#D6E4F0" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{x:Static loc:UiText.RecentEvents}" Foreground="#D6E4F0" FontWeight="SemiBold" Margin="0,8,0,4" />
                            <ItemsControl ItemsSource="{Binding RecentEvents}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#8FB3C7" TextWrapping="Wrap" Margin="0,0,0,4" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Background="#14202A" BorderBrush="#243746" BorderThickness="1" CornerRadius="10" Padding="12">
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:UiText.Settings}" Foreground="#D6E4F0" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <TextBlock Text="{x:Static loc:UiText.RtlSdrDevice}" Foreground="#AFC5D8" />
                            <ComboBox ItemsSource="{Binding AvailableDevices}" SelectedValue="{Binding SelectedDeviceId}" SelectedValuePath="DeviceId" DisplayMemberPath="Name" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding SelectedDeviceSummary}" Foreground="#D6E4F0" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding CenterLatitude, UpdateSourceTrigger=LostFocus}" Margin="0,0,8,8" />
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CenterLongitude, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding RadiusKilometers, UpdateSourceTrigger=LostFocus}" Margin="0,0,8,8" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DecoderPort, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                <TextBox Grid.Row="2" Grid.Column="0" Text="{Binding Gain, UpdateSourceTrigger=LostFocus}" Margin="0,0,8,8" />
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PpmCorrection, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                                <TextBox Grid.Row="3" Grid.Column="0" Text="{Binding SampleRate, UpdateSourceTrigger=LostFocus}" Margin="0,0,8,8" />
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DecoderHost, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />
                            </Grid>
                            <CheckBox Content="{x:Static loc:UiText.UseSimulationFallback}" IsChecked="{Binding UseSimulationFallback}" Foreground="#D6E4F0" Margin="0,0,0,10" />
                            <CheckBox Content="{x:Static loc:UiText.AiLogsEnabled}" IsChecked="{Binding AiLogsEnabled}" Foreground="#D6E4F0" Margin="0,0,0,10" />
                            <WrapPanel Margin="0,0,0,10">
                                <Button Content="{x:Static loc:UiText.OpenAiLogs}" Command="{Binding OpenAiLogsFolderCommand}" Padding="12,6" Margin="0,0,8,8" />
                                <Button Content="{x:Static loc:UiText.CopyAiPath}" Command="{Binding CopyAiLogsPathCommand}" Padding="12,6" Margin="0,0,0,8" />
                            </WrapPanel>
                            <Button Content="{x:Static loc:UiText.SaveSettings}" Command="{Binding SaveSettingsCommand}" Padding="12,6" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="3" Margin="0,12,0,0" Padding="12" Background="#14202A" BorderBrush="#243746" BorderThickness="1" CornerRadius="10">
            <TextBlock Text="{Binding StatusText}" Foreground="#E7F1F8" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
