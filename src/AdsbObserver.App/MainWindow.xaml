<Window x:Class="AdsbObserver.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:AdsbObserver.Core.Models;assembly=AdsbObserver.Core"
        mc:Ignorable="d"
        Title="ADS-B Offline Observer"
        Height="900"
        Width="1500"
        MinHeight="720"
        MinWidth="1180"
        Background="#10161C">
    <Window.Resources>
        <x:Array x:Key="MapLayerValues" Type="{x:Type models:MapLayerType}">
            <models:MapLayerType>Osm</models:MapLayerType>
            <models:MapLayerType>Satellite</models:MapLayerType>
        </x:Array>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Margin="0,0,0,12"
                Background="#19222B"
                BorderBrush="#273746"
                BorderThickness="1"
                CornerRadius="10">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left">
                    <Button Content="Start Live"
                            Command="{Binding StartLiveCommand}"
                            Padding="14,8"
                            Margin="0,0,8,0" />
                    <Button Content="Stop"
                            Command="{Binding StopLiveCommand}"
                            Padding="14,8"
                            Margin="0,0,8,0" />
                    <Button Content="Playback"
                            Command="{Binding StartPlaybackCommand}"
                            Padding="14,8"
                            Margin="0,0,8,0" />
                    <Button Content="Pause"
                            Command="{Binding PausePlaybackCommand}"
                            Padding="14,8"
                            Margin="0,0,8,0" />
                    <Button Content="Refresh SDR"
                            Command="{Binding RefreshDevicesCommand}"
                            Padding="14,8"
                            Margin="0,0,8,0" />
                    <Button Content="Download Map"
                            Command="{Binding DownloadMapCommand}"
                            Padding="14,8"
                            Margin="0,0,8,0" />
                    <Button Content="Import Recognition"
                            Click="ImportRecognition_Click"
                            Padding="14,8"
                            Margin="0,0,8,0" />
                    <Button Content="Export CSV"
                            Click="ExportCsv_Click"
                            Padding="14,8" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="Layer"
                               Margin="0,0,8,0"
                               Foreground="#D6E4F0"
                               VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{StaticResource MapLayerValues}"
                              SelectedItem="{Binding SelectedMapLayer}"
                              Width="140"
                              Margin="0,0,16,0" />
                    <TextBlock Text="Zoom"
                               Margin="0,0,8,0"
                               Foreground="#D6E4F0"
                               VerticalAlignment="Center" />
                    <Slider Minimum="5"
                            Maximum="12"
                            Value="{Binding SelectedZoom}"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Width="130" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Background="#0D141A"
                    BorderBrush="#273746"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="8">
                <Grid>
                    <Canvas x:Name="MapCanvas" Background="#0D141A" />
                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="12"
                            Padding="8"
                            CornerRadius="8"
                            Background="#B219222B">
                        <StackPanel>
                            <TextBlock Text="Observation Center"
                                       Foreground="#D6E4F0"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding CenterLatitude, StringFormat=Lat: {0:F4}}"
                                       Foreground="#AFC5D8" />
                            <TextBlock Text="{Binding CenterLongitude, StringFormat=Lon: {0:F4}}"
                                       Foreground="#AFC5D8" />
                            <TextBlock Text="{Binding RadiusKilometers, StringFormat=Radius: {0:F0} km}"
                                       Foreground="#AFC5D8" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#19222B"
                        BorderBrush="#273746"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListBox Grid.Row="0"
                                 ItemsSource="{Binding Tracks}"
                                 SelectedItem="{Binding SelectedTrack}"
                                 Background="#111920"
                                 BorderThickness="0"
                                 Foreground="#E7F1F8">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6"
                                            Padding="10"
                                            Background="#1D2A33"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Callsign}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Icao}" Foreground="#8FB3C7" />
                                                <TextBlock Text="{Binding PositionText}" Foreground="#8FB3C7" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding AltitudeText}" HorizontalAlignment="Right" />
                                                <TextBlock Text="{Binding SpeedText}" Foreground="#8FB3C7" HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="1"
                                Margin="0,12,0,0"
                                Padding="10"
                                Background="#111920"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Selected Track"
                                           Foreground="#D6E4F0"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="{Binding SelectedTrack.Icao, TargetNullValue=No selection}" Foreground="#E7F1F8" />
                                <TextBlock Text="{Binding SelectedTrack.Callsign, StringFormat=Callsign: {0}}" Foreground="#AFC5D8" />
                                <TextBlock Text="{Binding SelectedTrack.Registration, StringFormat=Registration: {0}}" Foreground="#AFC5D8" />
                                <TextBlock Text="{Binding SelectedTrack.AircraftType, StringFormat=Type: {0}}" Foreground="#AFC5D8" />
                                <TextBlock Text="{Binding SelectedTrack.Operator, StringFormat=Operator: {0}}" Foreground="#AFC5D8" />
                                <TextBlock Text="{Binding SelectedTrack.Country, StringFormat=Country: {0}}" Foreground="#AFC5D8" />
                                <TextBlock Text="{Binding SelectedTrack.PositionText, StringFormat=Position: {0}}" Foreground="#AFC5D8" />
                                <TextBlock Text="{Binding SelectedTrack.HeadingText, StringFormat=Heading: {0}}" Foreground="#AFC5D8" />
                                <TextBlock Text="{Binding SelectedTrack.Squawk, StringFormat=Squawk: {0}}" Foreground="#AFC5D8" />
                                <TextBlock Text="{Binding SelectedTrack.LastSeenText, StringFormat=Last Seen: {0}}" Foreground="#AFC5D8" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,12,0,0"
                        Padding="12"
                        Background="#19222B"
                        BorderBrush="#273746"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="{Binding DeviceStatusText}" Foreground="#D6E4F0" />
                        <TextBlock Text="{Binding ModeText}" Foreground="#AFC5D8" />
                        <TextBlock Text="{Binding MapStatusText}" Foreground="#AFC5D8" />
                        <TextBlock Text="{Binding RecognitionStatusText}" Foreground="#AFC5D8" />
                        <TextBlock Text="{Binding ActiveTrackCount, StringFormat=Active tracks: {0}}" Foreground="#AFC5D8" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="12"
                Background="#19222B"
                BorderBrush="#273746"
                BorderThickness="1"
                CornerRadius="10">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="#E7F1F8" />
        </Border>
    </Grid>
</Window>
