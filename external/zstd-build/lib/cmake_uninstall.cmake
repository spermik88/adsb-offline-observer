 
if(NOT EXISTS "C:/Users/bebra/Documents/Playground/external/zstd-build/install_manifest.txt")
  message(FATAL_ERROR "Cannot find install manifest: C:/Users/bebra/Documents/Playground/external/zstd-build/install_manifest.txt")
